# =============================================================
# Panel Web — Toyota Viola Presales
# Copiar como .env.prod y completar los valores reales
# NUNCA commitear .env.prod
# =============================================================

# PostgreSQL externo (misma DB que usa n8n/Baserow)
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db"

# NextAuth.js v5
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="reemplazar-con-valor-generado"
NEXTAUTH_URL="https://presales.tudominio.com"

# Dominio público (sin https://, sin trailing slash) — usado por Traefik
DOMAIN="presales.tudominio.com"

# Chatwoot
CHATWOOT_BASE_URL="https://chatwoot.mtdmcompany.com"
CHATWOOT_API_TOKEN="token-admin-de-chatwoot"

# Clave de encriptación para access_tokens en DB (32 bytes hex, 64 caracteres)
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY="reemplazar-con-valor-generado"

# Nombre de la app (se bake en el build, debe coincidir con el build-arg del Dockerfile)
NEXT_PUBLIC_APP_NAME="Toyota Viola · Presales"
