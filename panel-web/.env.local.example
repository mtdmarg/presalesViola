# =============================================================
# Panel Web - Toyota Viola Presales
# Copiar este archivo a .env.local y completar los valores
# =============================================================

# PostgreSQL — misma connection string que usa n8n
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db"

# NextAuth.js v5
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="reemplazar-con-valor-generado"
NEXTAUTH_URL="http://localhost:3000"

# Clave de encriptación para tokens de Chatwoot almacenados en DB
# Debe ser exactamente 32 bytes en hex (64 caracteres)
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY="reemplazar-con-valor-generado"

# Chatwoot
# URL base de la instancia de Chatwoot (sin trailing slash)
CHATWOOT_BASE_URL="https://chatwoot.tudominio.com"
# Token del usuario: Chatwoot → Perfil → Access Token
CHATWOOT_API_TOKEN="tu-api-access-token"

# Nombre que aparece en el navegador y en el panel
NEXT_PUBLIC_APP_NAME="Toyota Viola · Presales"
